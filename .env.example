POSTGRES_PASSWORD=localdev
INTERNAL_SECRET=dev-secret-change-in-prod
JWT_SECRET=dev-jwt-secret-minimum-32-chars-here

# LLM Provider: "openai" or "azure"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# Production: replace with Azure Monitor OTLP endpoint
