{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Archon — System Overview",
  "uid": "archon-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["archon"],
  "panels": [
    {
      "id": 1,
      "title": "Active Pipeline Runs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "active_pipeline_runs",
          "legendFormat": "Active runs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"archon-api\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 3,
      "title": "API Error Rate (5xx / req)",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"archon-api\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"archon-api\"}[5m]))",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "API P95 Latency",
      "type": "stat",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"archon-api\",uri=~\"/api/.*\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "LLM Token Rate (tokens/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[1m])) by (stage, direction)",
          "legendFormat": "{{stage}} / {{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      }
    },
    {
      "id": 6,
      "title": "Stage Duration — P50 / P95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p50 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 7,
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"archon-api\"} / 1048576",
          "legendFormat": "Heap used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\",job=\"archon-api\"} / 1048576",
          "legendFormat": "Heap max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 8,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"archon-api\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"archon-api\"}",
          "legendFormat": "Pending",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections{job=\"archon-api\"}",
          "legendFormat": "Total",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 9,
      "title": "Pipeline Runs Completed (total)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 10, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "sum(stage_duration_seconds_count{stage=\"architecture_review\"})",
          "legendFormat": "Completed runs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 10,
      "title": "Agent Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 20, "y": 10, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "archon-prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"archon-agent\"} / 1048576",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 1 } }
      }
    }
  ]
}
